# === BW-ENV CONFIGURATION TEMPLATE ===
# Copy this file to .env and adjust the values for your environment.
# DO NOT commit your actual .env file if it contains sensitive salts or IDs.

# Authorized Owner: The only Linux user permitted to load these secrets.
AUTHORIZED_USER="your_username"

# Bitwarden Item ID: The unique UUID of the secure note containing your API keys.
ITEM_ID="your-bitwarden-uuid-here"

# CRYPTOGRAPHIC SALT: Used to compartmentalize this tool's encryption.
# Change this to a unique string for your installation.
INTERNAL_SALT="BW_ENV_CHANGE_ME_2026"

# BACKGROUND SYNC: Interval in seconds between synchronization cycles.
CHECK_INTERVAL=300
MAX_AUTH_ATTEMPTS=3

# STABILIZATION DELAYS: Used during system wake-up for graphical session readiness.
WAKE_DEBOUNCE_DELAY=2
GRAPHICAL_WAIT_DELAY=1
AUTO_START_ON_BOOT=true
AUTO_START_ON_WAKE=false

# LOGGING: Tags used for identification in the system journal (journalctl).
DAEMON_TAG="bw-env-daemon"
LOG_TAG="bw-env"

# Paths & Bridges (Using $USER for multi-user safety in /dev/shm)
CACHE_GPG="$HOME/.bw/env/cache.env.gpg"
TEMP_ENV="/dev/shm/bw-$USER.env"
SESSION_FILE="/dev/shm/bw-session-$USER"
GPG_BRIDGE_FILE="/dev/shm/bw-gpg-$USER"
LOCK_FILE="/dev/shm/bw-env-$USER.lock"
LOCK_TIMEOUT=15

# Daemon Control & Registries
DAEMON_PID_FILE="/dev/shm/bw-env-daemon-$USER.pid"
DAEMON_STATE_FILE="/dev/shm/bw-env-daemon-$USER.state"
LAST_SYNC_FILE="/dev/shm/bw-env-$USER.lastsync"
KEYS_REGISTRY="/dev/shm/bw-keys-$USER.list"
SUBS_REGISTRY_INTERACTIVE="/dev/shm/bw-subs-interactive-$USER.list"
SUBS_REGISTRY_NON_INTERACTIVE="/dev/shm/bw-subs-noninteractive-$USER.list"

# Shell Loading: Non-blocking wait parameters.
LOAD_WAIT_MAX=20
LOAD_WAIT_STEP=0.1

# EXIT CODES: Standardized return values.
EXIT_SUCCESS=0
EXIT_CONFIG_ERR=1
EXIT_USER_CANCEL=2
EXIT_AUTH_ERR=3
EXIT_RETRIEVAL_ERR=4
EXIT_CRYPTO_ERR=5
EXIT_MAX_ATTEMPTS=6
